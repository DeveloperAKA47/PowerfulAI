    weight_decay: float
    amsgrad: bool
    def __init__(
        self,
        parameters: Iterable[Parameter],
        *,
        lr: float = 0.001,
        betas: tuple[float, float] = (0.9, 0.999),
        eps: float = 1e-08,
        weight_decay: float = 0.0,
        amsgrad: bool = False,
    ) -> None: ...
    def step(self) -> None: ...

class AdamW(Adam):
    def step(self) -> None: ...

