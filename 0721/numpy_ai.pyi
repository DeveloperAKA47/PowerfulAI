    weight: Parameter
    bias: Parameter | None
    def __init__(
        self,
        in_features: int,
        out_features: int,
        *,
        bias: bool = True,
        dtype: Any | None = None,
        rng: np.random.Generator | None = None,
    ) -> None: ...
    def forward(self, x: np.ndarray) -> np.ndarray: ...
    def backward(self, grad_output: np.ndarray) -> np.ndarray: ...

