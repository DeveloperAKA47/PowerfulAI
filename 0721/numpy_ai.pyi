class Loss(ABC):
    @abstractmethod
    def forward(self, prediction: ArrayLike, target: ArrayLike) -> Any: ...
    @abstractmethod
    def backward(self) -> np.ndarray: ...
    def __call__(self, prediction: ArrayLike, target: ArrayLike) -> Any: ...

