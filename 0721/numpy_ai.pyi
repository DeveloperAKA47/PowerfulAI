@dataclass(slots=True)
class Parameter:
    data: np.ndarray
    requires_grad: bool = True
    grad: np.ndarray | None = None
    def zero_grad(self) -> None: ...
    def accumulate_grad(self, gradient: ArrayLike) -> None: ...

class Module(ABC):
    training: bool
    def __init__(self) -> None: ...
    @abstractmethod
    def forward(self, x: np.ndarray) -> np.ndarray: ...
    @abstractmethod
    def backward(self, grad_output: np.ndarray) -> np.ndarray | None: ...
    def __call__(self, x: np.ndarray) -> np.ndarray: ...
    def named_parameters(self) -> Iterator[tuple[str, Parameter]]: ...
    def parameters(self) -> list[Parameter]: ...
    def named_modules(self) -> Iterator[tuple[str, Module]]: ...
    def train(self, mode: bool = True) -> Module: ...
    def eval(self) -> Module: ...
    def zero_grad(self) -> None: ...
    def state_dict(self) -> OrderedDict[str, np.ndarray]: ...
    def load_state_dict(
        self, state: Mapping[str, ArrayLike], *, strict: bool = True
    ) -> dict[str, list[str]]: ...

class Identity(Module):
    def __init__(self) -> None: ...
    def forward(self, x: np.ndarray) -> np.ndarray: ...
    def backward(self, grad_output: np.ndarray) -> np.ndarray: ...

