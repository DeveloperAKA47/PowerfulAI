class Optimizer(ABC):
    parameters: list[Parameter]
    lr: float
    step_count: int
    def __init__(self, parameters: Iterable[Parameter], *, lr: float) -> None: ...
    def zero_grad(self) -> None: ...
    @abstractmethod
    def step(self) -> None: ...

class SGD(Optimizer):
    momentum: float
    weight_decay: float
    dampening: float
    nesterov: bool
    def __init__(
        self,
        parameters: Iterable[Parameter],
        *,
        lr: float = 0.01,
        momentum: float = 0.0,
        weight_decay: float = 0.0,
        dampening: float = 0.0,
        nesterov: bool = False,
    ) -> None: ...
    def step(self) -> None: ...

class Adam(Optimizer):
    beta1: float
    beta2: float
